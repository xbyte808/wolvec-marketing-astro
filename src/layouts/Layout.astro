---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}

const {
  title = 'Wolvec',
  description = 'Wolvec — AI coaching for online fitness coaches. Your AI handles the routine. You handle what matters.',
  canonical = Astro.url.href,
} = Astro.props;

const canonicalUrl = canonical;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="canonical" href={canonicalUrl} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content="https://wolvec-marketing-astro.vercel.app/og-default.png" />
    <meta property="og:site_name" content="Wolvec" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://wolvec-marketing-astro.vercel.app/og-default.png" />

    <slot name="head" />
  </head>
  <body class="bg-brand text-white font-sans antialiased">
    <Nav />
    <slot />
    <Footer />
  </body>
</html>
