---
const tiers = [
  {
    label: 'Autonomous',
    tag: 'Wolvec default',
    tagStyle: 'bg-green-500/20 text-green-400',
    description:
      'AI acts without your involvement. Best for standard Q&A, content delivery, check-in reminders, and routine encouragement, the interactions that are valuable but don\'t require your judgment.',
  },
  {
    label: 'Autonomous with override',
    tag: 'Wolvec default',
    tagStyle: 'bg-green-500/20 text-green-400',
    description:
      'AI acts, but you can intercept any specific conversation at any time. Best for routine program-adherence conversations, scheduling adjustments, and motivation exchanges where you want oversight without being in every thread.',
  },
  {
    label: 'Drafted for review',
    tag: 'Required for safety-sensitive',
    tagStyle: 'bg-yellow-500/20 text-yellow-400',
    description:
      'AI drafts the response; you approve before it reaches the client. Required for program changes, nutrition adjustments, and anything flagged as safety-sensitive. The AI does the work. You make the call.',
  },
  {
    label: 'Off',
    tag: 'Full coach control',
    tagStyle: 'bg-neutral-700/50 text-neutral-400',
    description:
      'No AI involvement in this category. You own the interaction entirely. Available for any category at your discretion.',
  },
];
---

<section id="autonomy" class="py-24 px-6 bg-brand">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-4xl font-bold text-white mb-4">You control what the AI handles</h2>
      <p class="text-neutral-400 text-lg max-w-2xl mx-auto">
        Per-category toggles. Wolvec-recommended defaults. Clear liability language at every setting.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      {tiers.map((tier, i) => (
        <div class="bg-brand-muted border border-white/10 rounded-xl p-6 flex flex-col gap-3">
          <div class="flex items-center gap-3">
            <span class="text-neutral-400 text-sm font-mono">0{i + 1}</span>
            <h3 class="text-white font-semibold text-lg">{tier.label}</h3>
            <span class={`ml-auto text-xs font-semibold px-3 py-1 rounded-full ${tier.tagStyle}`}>
              {tier.tag}
            </span>
          </div>
          <p class="text-neutral-400 leading-relaxed text-sm">{tier.description}</p>
        </div>
      ))}
    </div>

    <p class="text-center text-neutral-400 text-sm">
      Adjust any category at any time. Settings show the liability implication of each choice in
      plain language, not fine print.
    </p>
  </div>
</section>
