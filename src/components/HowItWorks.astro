---
import { Image } from 'astro:assets';
import step01Photo from '../assets/photos/step-01.jpg';
import step02Photo from '../assets/photos/step-02.jpg';
import step03Photo from '../assets/photos/step-03.jpg';

const steps = [
  {
    number: '01',
    title: 'Talk it through',
    body: 'One guided conversation about how you program and coach. You just answer.',
    photo: step01Photo,
  },
  {
    number: '02',
    title: 'We build your clone',
    body: 'An AI that carries your methodology and how you’d coach it.',
    photo: step02Photo,
  },
  {
    number: '03',
    title: "It's on when you're off",
    body: 'Chat, check-ins, and accountability, handled the way you would, while you take the next client.',
    photo: step03Photo,
  },
];
---

<section id="how-it-works" class="bg-ink">
  <div class="max-w-5xl mx-auto px-6 pt-16 pb-2">
    <p class="font-label text-azure text-xs uppercase tracking-[0.24em] mb-3">How it works</p>
    <h2 class="font-display text-text max-w-2xl text-[clamp(1.875rem,3vw+1rem,2.75rem)] leading-[0.98]">
      One conversation does the heavy lifting.
    </h2>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 mt-9">
    {steps.map((step, i) => (
      <div
        class:list={[
          'relative min-h-[420px] flex items-end p-8',
          i < steps.length - 1 && 'md:border-r border-hairline-dark',
        ]}
      >
        <Image
          src={step.photo}
          alt=""
          width={900}
          height={640}
          format="webp"
          quality={75}
          class="absolute inset-0 h-full w-full object-cover"
          style="filter: grayscale(0.35) brightness(0.5)"
        />
        <div class="absolute inset-0 bg-gradient-to-b from-transparent to-ink/95"></div>
        <div class="relative">
          <p class="font-display text-azure text-5xl leading-[0.8] mb-3">{step.number}</p>
          <h3 class="font-display text-white text-2xl mb-2">{step.title}</h3>
          <p class="text-[#CFD2D7] text-[15.5px]">{step.body}</p>
        </div>
      </div>
    ))}
  </div>
</section>
