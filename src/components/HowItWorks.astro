---
---

<section id="how-it-works" class="py-24 lg:py-32 px-6 lg:px-8 bg-slate-50">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-semibold text-slate-950 tracking-tight mb-4">How it works</h2>
      <p class="text-slate-600 text-lg">From interview to deployed clone in one session.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12">
      <!-- Step 1 -->
      <div class="flex flex-col gap-4">
        <div class="w-12 h-12 rounded-xl bg-slate-100 flex items-center justify-center">
          <svg class="w-6 h-6 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round"
              d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
          </svg>
        </div>
        <div>
          <p class="text-slate-500 text-sm font-semibold uppercase tracking-wider mb-2">Step 1</p>
          <h3 class="text-xl font-semibold text-slate-950 mb-3">30-minute AI interview</h3>
          <p class="text-slate-700 leading-relaxed">
            A structured AI-driven conversation captures your coaching philosophy, methodology, tone,
            how you handle common client situations, and the questions you answer most. No prep needed,
            and no content library required.
          </p>
        </div>
      </div>

      <!-- Step 2 -->
      <div class="flex flex-col gap-4">
        <div class="w-12 h-12 rounded-xl bg-slate-100 flex items-center justify-center">
          <svg class="w-6 h-6 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round"
              d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
          </svg>
        </div>
        <div>
          <p class="text-slate-500 text-sm font-semibold uppercase tracking-wider mb-2">Step 2</p>
          <h3 class="text-xl font-semibold text-slate-950 mb-3">Your AI clone is configured</h3>
          <p class="text-slate-700 leading-relaxed">
            The interview output becomes your AI clone trained on your voice, your approach, and
            your answers. You review and edit before it goes live.
          </p>
        </div>
      </div>

      <!-- Step 3 -->
      <div class="flex flex-col gap-4">
        <div class="w-12 h-12 rounded-xl bg-slate-100 flex items-center justify-center">
          <svg class="w-6 h-6 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round"
              d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
        </div>
        <div>
          <p class="text-slate-500 text-sm font-semibold uppercase tracking-wider mb-2">Step 3</p>
          <h3 class="text-xl font-semibold text-slate-950 mb-3">Clone handles the day-to-day</h3>
          <p class="text-slate-700 leading-relaxed">
            Your clone responds to client check-ins, answers routine questions, delivers programs,
            and sends accountability nudges, with you in control of how much it handles and when it
            escalates.
          </p>
        </div>
      </div>
    </div>

    <!-- Feature Image -->
    <div class="mt-16">
      <div class="relative rounded-2xl overflow-hidden shadow-sm">
        <img
          src="https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?w=1200&h=500&fit=crop&crop=center"
          alt="Personal trainer reviewing workout data with a client"
          class="w-full h-auto object-cover"
        />
      </div>
    </div>
  </div>
</section>
