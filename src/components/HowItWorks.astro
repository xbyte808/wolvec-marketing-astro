---
const steps = [
  {
    number: '01',
    title: 'Talk it through',
    body: 'A 30-minute guided interview about how you program and coach. You just answer.',
  },
  {
    number: '02',
    title: 'We build your clone',
    body: 'An AI that carries your methodology and how you’d coach it. No uploads, no prompt engineering.',
  },
  {
    number: '03',
    title: 'It runs the in-between',
    body: 'Chat, check-ins, accountability — handled the way you’d say it, while you take the next client.',
  },
];
---

<section id="how-it-works" class="py-24 px-6 bg-ink">
  <div class="max-w-5xl mx-auto">
    <h2 class="font-display text-text mb-16 max-w-2xl text-[clamp(1.875rem,3vw+1rem,2.75rem)]">
      Three steps. One conversation does the heavy lifting.
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
      {steps.map((step) => (
        <div class="flex flex-col gap-4">
          <p class="font-label text-azure-deep text-sm">{step.number}</p>
          <h3 class="font-display text-text text-xl">{step.title}</h3>
          <p class="text-text-soft leading-relaxed text-[15.5px]">{step.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
