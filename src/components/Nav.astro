---
import Logo from '../assets/wolvec-logo.svg';
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-ink/72 backdrop-blur-md border-b border-hairline-dark">
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="flex items-center gap-3">
      <img src={Logo.src} alt="Wolvec" class="h-7 w-7" />
      <span class="hidden sm:inline font-display text-text text-xl uppercase tracking-[0.06em]">Wolvec</span>
    </a>

    <div class="hidden md:flex items-center gap-7">
      <a href="/#how-it-works" class="text-text-soft hover:text-text transition-colors text-sm font-medium">
        How it works
      </a>
      <a href="/#your-control" class="text-text-soft hover:text-text transition-colors text-sm font-medium">
        Your control
      </a>
      <a
        href="/#early-access"
        class="bg-azure-deep hover:bg-azure-deep/90 text-white text-sm font-bold px-5 py-2.5 rounded-full transition-colors"
      >
        Get early access
      </a>
    </div>

    <!-- Mobile: logo mark + CTA only -->
    <div class="flex md:hidden">
      <a
        href="/#early-access"
        class="bg-azure-deep hover:bg-azure-deep/90 text-white text-sm font-bold px-4 py-2.5 rounded-full transition-colors"
      >
        Get early access
      </a>
    </div>
  </div>
</nav>
