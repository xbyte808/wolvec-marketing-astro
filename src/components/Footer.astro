---
import Logo from '../assets/wolvec-logo.svg';
---

<footer class="border-t border-hairline-dark bg-ink">
  <div class="max-w-6xl mx-auto px-6 py-12 flex flex-col gap-8">
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
      <div class="flex items-center gap-2.5">
        <img src={Logo.src} alt="Wolvec" class="h-6 w-6" />
        <div>
          <span class="font-display text-text text-lg">Wolvec</span>
          <p class="text-text-soft text-sm mt-0.5">The AI version of you.</p>
        </div>
      </div>

      <div class="flex flex-wrap items-center gap-x-8 gap-y-2 text-sm text-text-soft">
        <a href="/privacy" class="hover:text-text transition-colors">Privacy Policy</a>
        <a href="mailto:ellard@wolvec.ai" class="hover:text-text transition-colors">Contact</a>
      </div>
    </div>

    <p class="text-text-soft text-xs">A Veccor company. &middot; &copy; 2026 Wolvec L.L.C.</p>
  </div>
</footer>
