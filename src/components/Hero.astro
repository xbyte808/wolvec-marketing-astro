<section id="hero" class="pt-32 pb-24 lg:pb-32 px-6 lg:px-8 text-center bg-white">
  <div class="max-w-4xl mx-auto">
    <p class="text-slate-500 text-sm font-semibold uppercase tracking-widest mb-6">
      Built for online fitness coaches
    </p>

    <h1 class="text-4xl md:text-5xl lg:text-6xl font-semibold text-slate-950 leading-tight tracking-tight mb-6 text-balance">
      AI handles the routine.<br />
      You handle what matters.
    </h1>

    <p class="text-slate-700 text-lg md:text-xl max-w-2xl mx-auto mb-10 leading-relaxed">
      Wolvec creates an AI clone of you through a 30-minute interview without requiring a content library.
      Your clone handles client check-ins, answers questions, and delivers programs while you stay
      focused on the work that demands your judgment.
    </p>

    <a
      href="#early-access"
      class="inline-block bg-slate-800 hover:bg-slate-900 text-white font-medium text-lg px-6 py-3 rounded-lg transition-colors"
    >
      Request access
    </a>

    <p class="text-slate-500 text-sm mt-4">
      Currently onboarding design-partner coaches. Limited spots.
    </p>
  </div>

  <!-- Hero Image -->
  <div class="max-w-5xl mx-auto mt-16">
    <div class="relative rounded-2xl overflow-hidden shadow-md">
      <img
        src="https://images.unsplash.com/photo-1571019614242-c5c5dee9f50b?w=1200&h=600&fit=crop&crop=center"
        alt="Fitness coach working with a client in a modern gym setting"
        class="w-full h-auto object-cover"
      />
      <div class="absolute inset-0 bg-slate-900/60 flex items-center justify-center">
        <div class="text-center px-6">
          <p class="text-white/90 text-sm font-medium uppercase tracking-widest mb-2">Wolvec</p>
          <p class="text-white text-2xl md:text-3xl font-semibold tracking-tight">Your coaching, amplified by AI</p>
        </div>
      </div>
    </div>
  </div>
</section>
