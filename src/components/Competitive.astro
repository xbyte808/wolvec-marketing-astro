---
const rows = [
  {
    platform: 'Coachvox AI',
    whatTheyDo: 'AI clone tool for coaches (any vertical)',
    gap: 'Requires an existing content library to clone from. No fitness-vertical focus. No intake interview.',
  },
  {
    platform: 'Delphi.ai',
    whatTheyDo: 'AI clone with monetization features (any vertical)',
    gap: 'Horizontal positioning — not built for fitness coaching. No guided intake. Broad IP license in ToS is a risk for coaches with proprietary frameworks.',
  },
  {
    platform: 'Trainerize',
    whatTheyDo: 'Full-stack coaching ops platform with AI-assisted workflow tools (AI Workout Builder, Smart Meal Planner, summaries)',
    gap: 'No coach clone. Explicit positioning: "You\'re still the coach." AI supports; it doesn\'t replace your presence between sessions. You still answer every DM.',
  },
  {
    platform: 'Everfit',
    whatTheyDo: 'Full-stack coaching ops platform with AI-assisted programming and group coaching tools',
    gap: 'No coach clone. Coaches still handle all client messaging manually.',
  },
  {
    platform: 'TrueCoach',
    whatTheyDo: 'Workout delivery and coach-client messaging, athletic and performance focus',
    gap: 'No coach clone. Messaging is human-only.',
  },
];
---

<section id="compare" class="py-24 lg:py-32 px-6 lg:px-8 bg-slate-50">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-semibold text-slate-950 tracking-tight mb-4">Where Wolvec fits</h2>
      <p class="text-slate-600 text-lg">
        Most tools make you a better coach manager. Wolvec makes you a coach who scales.
      </p>
    </div>

    <!-- Desktop table -->
    <div class="hidden md:block overflow-hidden rounded-xl border border-slate-200 mb-10 shadow-sm">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-slate-100 border-b border-slate-200">
            <th class="text-left text-slate-700 font-semibold px-6 py-4 w-36">Platform</th>
            <th class="text-left text-slate-700 font-semibold px-6 py-4">What they do</th>
            <th class="text-left text-slate-700 font-semibold px-6 py-4">The gap</th>
          </tr>
        </thead>
        <tbody>
          {rows.map((row, i) => (
            <tr class={`border-b border-slate-100 ${i % 2 === 0 ? 'bg-white' : 'bg-slate-50/50'}`}>
              <td class="px-6 py-5 text-slate-950 font-semibold align-top">{row.platform}</td>
              <td class="px-6 py-5 text-slate-600 align-top leading-relaxed">{row.whatTheyDo}</td>
              <td class="px-6 py-5 text-slate-600 align-top leading-relaxed">{row.gap}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <!-- Mobile cards -->
    <div class="md:hidden flex flex-col gap-4 mb-10">
      {rows.map((row) => (
        <div class="bg-white border border-slate-200 rounded-xl p-5 flex flex-col gap-3 shadow-sm">
          <h3 class="text-slate-950 font-semibold">{row.platform}</h3>
          <p class="text-slate-600 text-sm leading-relaxed">{row.whatTheyDo}</p>
          <div class="border-t border-slate-100 pt-3">
            <p class="text-slate-500 text-xs font-semibold uppercase tracking-wider mb-1">The gap</p>
            <p class="text-slate-600 text-sm leading-relaxed">{row.gap}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Callout -->
    <div class="bg-white border border-slate-200 rounded-xl p-8 shadow-sm">
      <h3 class="text-slate-950 font-semibold text-xl mb-3">The Wolvec difference</h3>
      <p class="text-slate-700 leading-relaxed">
        A 30-minute AI-driven intake interview creates your clone from a conversation. Works for
        coaches who are new to online coaching and have no existing content library.
        Fitness-vertical-native and not a horizontal tool repackaged for coaches. Your clone replaces
        your presence between sessions, not just your program delivery.
      </p>
    </div>

    <!-- Feature Image -->
    <div class="mt-12">
      <div class="relative rounded-2xl overflow-hidden shadow-sm">
        <img
          src="https://images.unsplash.com/photo-1534438327276-14e5300c3a48?w=1200&h=500&fit=crop&crop=center"
          alt="Modern gym with fitness equipment"
          class="w-full h-auto object-cover"
        />
      </div>
    </div>
  </div>
</section>
