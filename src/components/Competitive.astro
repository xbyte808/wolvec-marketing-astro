---
const rows = [
  {
    platform: 'Coachvox AI',
    whatTheyDo: 'AI clone tool for coaches (any vertical)',
    gap: 'Requires an existing content library: books, blogs, podcasts. Mid-tier coaches without published content cannot use it.',
    isWolvec: false,
  },
  {
    platform: 'Delphi.ai',
    whatTheyDo: 'AI clone with monetization features (any vertical)',
    gap: 'Targets seven-figure creators (Robbins, Hussey, Hyman). Requires heavy audio and video content uploads. Not positioned for working online coaches.',
    isWolvec: false,
  },
  {
    platform: 'Personal AI',
    whatTheyDo: 'Personal AI assistant built from your data',
    gap: 'Requires chat archives and voice memos. No fitness coaching focus. No coach-to-client deployment layer.',
    isWolvec: false,
  },
  {
    platform: 'Custom GPTs',
    whatTheyDo: 'Custom ChatGPT experience built from uploaded files',
    gap: 'Requires uploaded files to train from. Clients need a ChatGPT account. No branded interface, no persistent memory, no lead capture.',
    isWolvec: false,
  },
  {
    platform: 'Wolvec',
    whatTheyDo: 'AI coaching layer for online fitness coaches',
    gap: 'NO content library required. Built from one conversation. Fitness-vertical-native. Mid-tier coach focus (10K-100K followers).',
    isWolvec: true,
  },
];
---

<section id="compare" class="py-24 px-6 bg-brand-muted">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-4xl font-bold text-white mb-4">Where Wolvec fits</h2>
      <p class="text-neutral-400 text-lg">
        Most tools make you a better coach manager. Wolvec makes you a coach who scales.
      </p>
    </div>

    <!-- Desktop table -->
    <div class="hidden md:block overflow-hidden rounded-xl border border-white/10 mb-10">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-white/5 border-b border-white/10">
            <th class="text-left text-neutral-400 font-semibold px-6 py-4 w-36">Platform</th>
            <th class="text-left text-neutral-400 font-semibold px-6 py-4">What they do</th>
            <th class="text-left text-neutral-400 font-semibold px-6 py-4">The gap</th>
          </tr>
        </thead>
        <tbody>
          {rows.map((row, i) => (
            <tr class={`border-b border-white/5 ${row.isWolvec ? 'bg-brand-accent/10 border-brand-accent/20' : (i % 2 === 0 ? 'bg-brand/30' : '')}`}>
              <td class={`px-6 py-5 font-semibold align-top ${row.isWolvec ? 'text-brand-accent' : 'text-white'}`}>{row.platform}</td>
              <td class="px-6 py-5 text-neutral-400 align-top leading-relaxed">{row.whatTheyDo}</td>
              <td class={`px-6 py-5 align-top leading-relaxed ${row.isWolvec ? 'text-brand-accent font-medium' : 'text-neutral-400'}`}>{row.gap}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <!-- Mobile cards -->
    <div class="md:hidden flex flex-col gap-4 mb-10">
      {rows.map((row) => (
        <div class={`border rounded-xl p-5 flex flex-col gap-3 ${row.isWolvec ? 'bg-brand-accent/10 border-brand-accent/30' : 'bg-brand border-white/10'}`}>
          <h3 class={`font-semibold ${row.isWolvec ? 'text-brand-accent' : 'text-white'}`}>{row.platform}</h3>
          <p class="text-neutral-400 text-sm leading-relaxed">{row.whatTheyDo}</p>
          <div class="border-t border-white/10 pt-3">
            <p class="text-brand-accent text-xs font-semibold uppercase tracking-wider mb-1">{row.isWolvec ? 'Why Wolvec' : 'The gap'}</p>
            <p class={`text-sm leading-relaxed ${row.isWolvec ? 'text-brand-accent font-medium' : 'text-neutral-400'}`}>{row.gap}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Callout -->
    <div class="bg-brand border border-brand-accent/30 rounded-xl p-8">
      <h3 class="text-white font-bold text-xl mb-3">The Wolvec difference</h3>
      <p class="text-neutral-400 leading-relaxed">
        Every alternative requires content you have to create before your AI can work. Coachvox
        needs your blog. Delphi needs your podcast. Personal AI needs your chat history. Custom
        GPTs need uploaded files. Wolvec builds your AI from one conversation. If you coach
        clients online, that conversation is all you need.
      </p>
    </div>
  </div>
</section>
