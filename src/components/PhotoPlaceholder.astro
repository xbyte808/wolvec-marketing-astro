---
// Stands in for a mockup photo slot whose stock-image license could not be
// verified (no EXIF/source data, real identifiable people in frame). Renders
// a branded, obviously-synthetic graphic instead of shipping the unverified
// JPEG — swap for a licensed asset once one is confirmed.
interface Props {
  class?: string;
  label?: string;
}

const { class: className = '', label = 'Photo placeholder — pending licensed asset' } = Astro.props;

// SVG defs are referenced by id — with multiple placeholders on one page,
// duplicate ids break the gradient/pattern lookup, so each instance gets its own.
const uid = crypto.randomUUID();
const gradId = `ph-grad-${uid}`;
const stripesId = `ph-stripes-${uid}`;
---

<div class={`overflow-hidden bg-surface-2 ${className}`}>
  <svg class="absolute inset-0 h-full w-full" preserveAspectRatio="xMidYMid slice" viewBox="0 0 400 300" xmlns="http://www.w3.org/2000/svg">
    <defs>
      <radialGradient id={gradId} cx="50%" cy="38%" r="80%">
        <stop offset="0%" stop-color="#2A3350" />
        <stop offset="100%" stop-color="#15171C" />
      </radialGradient>
      <pattern id={stripesId} width="18" height="18" patternTransform="rotate(45)" patternUnits="userSpaceOnUse">
        <rect width="18" height="18" fill="transparent" />
        <line x1="0" y1="0" x2="0" y2="18" stroke="rgba(255,255,255,0.09)" stroke-width="9" />
      </pattern>
    </defs>
    <rect width="400" height="300" fill={`url(#${gradId})`} />
    <rect width="400" height="300" fill={`url(#${stripesId})`} />
    <rect x="10" y="10" width="380" height="280" fill="none" stroke="rgba(255,255,255,0.25)" stroke-width="2" stroke-dasharray="6 6" />
    <g transform="translate(200 150) scale(.12) translate(-1000 -1000)" opacity="0.85">
      <path d="M663.016 1093.82L619.283 947.54L727.232 1031.76L829.092 1185.8L663.016 1093.82Z" fill="#5C82FF" />
      <path d="M1337.98 1093.27L1381.71 946.986L1273.77 1031.21L1171.91 1185.25L1337.98 1093.27Z" fill="#5C82FF" />
      <path d="M1569 184L1105.22 817.328L1000.5 647.776L895.776 817.882L432 184.554L674.139 846.141L865.301 1171.95L1000.5 945.878L1135.7 1171.39L1326.86 845.587L1569 184Z" fill="#8A8F99" />
      <path d="M1395.01 1128.17L1168.4 1235.2L1000.5 1620.61L832.595 1235.2L605.984 1128.17L1000.5 1816.36L1395.01 1128.17Z" fill="#8A8F99" />
    </g>
  </svg>
  <p class="absolute top-3 left-1/2 -translate-x-1/2 whitespace-nowrap rounded-full bg-black/55 px-3 py-1 font-label text-[10px] uppercase tracking-widest text-white/90">
    {label}
  </p>
</div>
