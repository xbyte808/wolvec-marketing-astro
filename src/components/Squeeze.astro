---
const points = [
  {
    label: 'Never ending',
    body: 'Workout swaps, form checks, quick questions, every hour, from every client.',
  },
  {
    label: 'Nothing runs itself',
    body: 'Check-ins, nudges, follow-ups. If you don’t send it, it doesn’t happen.',
  },
  {
    label: 'Nothing to start with',
    body: 'Coaching apps expect a back catalog of programs you may not have yet.',
  },
];
---

<section id="squeeze" class="py-21 px-6 bg-paper-1 text-on-paper">
  <div class="max-w-5xl mx-auto">
    <p class="font-label text-azure-deep text-xs uppercase tracking-[0.24em] mb-3">Where it breaks down</p>
    <h2 class="font-display text-on-paper mb-11 max-w-2xl text-[clamp(1.875rem,3vw+1rem,2.75rem)] leading-[0.98]">
      The parts nobody tells you about scaling coaching.
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      {points.map((p) => (
        <div class="border border-hairline-light rounded-2xl p-6 bg-paper-2">
          <h3 class="font-display text-on-paper text-xl mb-2">{p.label}</h3>
          <p class="text-on-paper-soft text-[15.5px] leading-relaxed">{p.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
