---
const points = [
  {
    label: 'Always on',
    body: 'Check-ins, form questions, "can I swap this" — every hour, every client, all landing in one inbox.',
  },
  {
    label: 'Capped by time',
    body: 'More clients means more messages. At some point you stop selling spots you can’t serve.',
  },
  {
    label: 'No library',
    body: 'Every "AI coach" wants a back catalog you never built. Yours lives in your head and your DMs.',
  },
];
---

<section id="squeeze" class="py-21 px-6 bg-paper-1 text-on-paper">
  <div class="max-w-5xl mx-auto">
    <p class="font-label text-azure-deep text-xs uppercase tracking-[0.24em] mb-3">The squeeze</p>
    <h2 class="font-display text-on-paper mb-11 max-w-2xl text-[clamp(1.875rem,3vw+1rem,2.75rem)] leading-[0.98]">
      You didn&rsquo;t start coaching to answer the same DM forty times.
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      {points.map((p) => (
        <div class="border border-hairline-light rounded-2xl p-6 bg-paper-2">
          <h3 class="font-display text-on-paper text-xl mb-2">{p.label}</h3>
          <p class="text-on-paper-soft text-[15.5px] leading-relaxed">{p.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
