---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Consumer Health Data Privacy Policy | Wolvec"
  description="Wolvec's Consumer Health Data Privacy Policy is being finalized."
>
  <main class="pt-32 pb-24 px-6 min-h-screen">
    <div class="max-w-3xl mx-auto">

      <h1 class="text-4xl font-bold text-white mb-2">Consumer Health Data Privacy Policy</h1>
      <p class="text-sm text-neutral-500 mb-8">Wolvec L.L.C.</p>

      <p class="text-neutral-300 leading-relaxed mb-4">
        This page is being finalized. Wolvec's Consumer Health Data Privacy Policy, addressing
        consumer health data as defined under Washington's My Health My Data Act and other
        applicable consumer health data laws, will be published here shortly.
      </p>
      <p class="text-neutral-300 leading-relaxed mb-4">
        In the meantime, questions about consumer health data can be directed to
        <a href="mailto:privacy@wolvec.ai" class="text-brand-accent hover:underline">privacy@wolvec.ai</a>.
      </p>

    </div>
  </main>
</Layout>
