---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Blog | Wolvec"
  description="Thinking on AI, fitness coaching, and building Wolvec, from the team."
>
  <main class="pt-32 pb-24 px-6 min-h-screen">
    <div class="max-w-2xl mx-auto text-center">
      <h1 class="text-4xl font-bold text-white mb-4">Blog</h1>
      <p class="text-neutral-400 text-lg mb-6 leading-relaxed">
        Thinking on AI, fitness coaching, and what we're learning from coaches in early access.
      </p>
      <p class="text-neutral-400 mb-8">
        No posts yet. We're heads-down in early access. Posts begin when we have real usage to
        write from.
      </p>
      <a
        href="/#early-access"
        class="inline-block text-brand-accent hover:text-brand-accent/80 font-semibold transition-colors"
      >
        Apply for early access &rarr;
      </a>
    </div>
  </main>
</Layout>
