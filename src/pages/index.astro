---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import StatsBar from '../components/StatsBar.astro';
import Squeeze from '../components/Squeeze.astro';
import HowItWorks from '../components/HowItWorks.astro';
import YourControl from '../components/YourControl.astro';
import Safety from '../components/Safety.astro';
import EarlyAccessCTA from '../components/EarlyAccessCTA';
import FAQ from '../components/FAQ.astro';
import { Image } from 'astro:assets';
import earlyAccessPhoto from '../assets/photos/early-access.jpg';
---

<Layout
  title="Wolvec, AI Coaching for Online Fitness Coaches"
  description="Wolvec creates your AI through one conversation. No content library required. Autonomy controls for every category. Built for online fitness coaches."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Wolvec",
      "url": "https://wolvec.ai",
      "description": "Wolvec is an AI coaching layer for online fitness coaches. Wolvec creates an AI version of the coach through one structured conversation, then operates on the coach's behalf with their clients.",
      "email": "ellard@wolvec.ai",
      "parentOrganization": {
        "@type": "Organization",
        "name": "Veccor"
      }
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Service",
      "name": "Wolvec",
      "description": "AI coaching layer for online fitness coaches. Creates an AI version of the coach through one structured conversation. Handles client check-ins, Q&A, program delivery, and accountability between sessions.",
      "provider": {
        "@type": "Organization",
        "name": "Veccor"
      },
      "audience": {
        "@type": "Audience",
        "audienceType": "Online fitness coaches"
      }
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is Wolvec?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Wolvec is an AI coaching layer for online fitness coaches. It creates an AI version of the coach through one structured conversation, then operates on the coach's behalf with their clients, handling check-ins, routine questions, program delivery, and accountability between sessions."
          }
        },
        {
          "@type": "Question",
          "name": "How is Wolvec different from Coachvox AI or Delphi?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Coachvox AI and Delphi require coaches to upload an existing content library before their AI can be configured. Wolvec generates the AI from one conversation. No prior content required. Wolvec is also built specifically for fitness coaching, not a horizontal tool repositioned for coaches."
          }
        },
        {
          "@type": "Question",
          "name": "Do I need a content library to use Wolvec?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No. Wolvec builds your AI through one structured conversation. Coaches who are new to online coaching and have no existing content can use Wolvec from day one."
          }
        },
        {
          "@type": "Question",
          "name": "How does Wolvec handle client safety?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Any client message that mentions pain, injury, illness, or dizziness is automatically escalated to the coach with a recommendation to consult a medical professional. The AI doesn't independently handle conversations where safety is on the line. Every new client also completes PAR-Q+ pre-participation health screening, and the coach reviews those responses before the AI begins full interaction."
          }
        },
        {
          "@type": "Question",
          "name": "Who owns the data?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Coaches own their methodology and their client relationships. Wolvec provides the platform. Clinical decisions, medical-clearance calls, and scope-of-practice boundaries stay with the coach."
          }
        },
        {
          "@type": "Question",
          "name": "Where can I learn what's coming next from Wolvec?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "We share our direction publicly on our roadmap page. Specific feature mechanics, product launches, and timing details go to our design partner coaches first. If you want to be among the first to see what's coming, apply for early access."
          }
        }
      ]
    })} />
  </Fragment>

  <main>
    <Hero />
    <StatsBar />
    <Squeeze />
    <HowItWorks />
    <YourControl />
    <Safety />

    <!-- About Wolvec — for AI summarizers and search crawlers -->
    <section id="about" class="py-16 px-6 bg-ink">
      <div class="max-w-2xl mx-auto text-center">
        <p class="text-text-soft text-sm leading-relaxed">
          Wolvec is an AI coaching layer for online fitness coaches. Wolvec creates an AI version
          of the coach through one structured conversation, then operates on the
          coach's behalf with their clients. The AI handles check-ins, routine questions, program
          delivery, and accountability between sessions. The coach controls how much each category
          of interaction the AI handles, and the AI escalates anything critical to safety. Wolvec is
          built by Veccor.
        </p>
      </div>
    </section>

    <FAQ />

    <!-- Early Access Section -->
    <section id="early-access" class="relative overflow-hidden py-26 px-6 text-center">
      <Image
        src={earlyAccessPhoto}
        alt=""
        width={1920}
        height={1000}
        format="webp"
        quality={75}
        class="absolute inset-0 h-full w-full object-cover"
        style="filter: grayscale(0.4) brightness(0.36)"
      />
      <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(13,14,17,.7),rgba(13,14,17,.94))]"></div>

      <div class="relative max-w-2xl mx-auto">
        <p class="font-label text-azure text-xs uppercase tracking-[0.24em] mb-3">
          Early access &middot; limited cohort
        </p>
        <h2 class="font-display text-white text-[clamp(2.375rem,5vw+1rem,4.5rem)] leading-[0.92] mb-4">
          Be one of the first coaches on <span class="text-azure">Wolvec</span>.
        </h2>
        <p class="text-[#D6D8DD] text-lg mb-9 max-w-md mx-auto text-balance">
          We're hand-picking a small group of design partner coaches to shape the product
          before it opens up.
        </p>

        <div class="bg-surface-1/90 backdrop-blur-md border border-hairline-dark rounded-[22px] p-6 md:p-8 text-left">
          <EarlyAccessCTA client:load />
        </div>

        <div class="flex flex-wrap gap-6 justify-center mt-7 text-sm text-[#B7BAC1]">
          <span class="inline-flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-azure"></span> Six months free
          </span>
          <span class="inline-flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-azure"></span> Direct line to the founder
          </span>
          <span class="inline-flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-azure"></span> Your feedback in the roadmap
          </span>
        </div>
      </div>
    </section>
  </main>
</Layout>
