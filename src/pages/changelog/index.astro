---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Changelog | Wolvec" description="Wolvec ships in public. Every change we make to the platform is logged here.">
  <main class="pt-32 pb-24 px-6 min-h-screen">
    <div class="max-w-2xl mx-auto text-center">
      <h1 class="text-4xl font-bold text-white mb-4">Changelog</h1>
      <p class="text-neutral-400 text-lg mb-6">
        We ship in public. Check back here for updates as we build.
      </p>
      <p class="text-neutral-400 mb-8">
        No entries yet — we're in early access. Subscribe to updates by applying below.
      </p>
      <a
        href="/#early-access"
        class="inline-block text-brand-accent hover:text-brand-accent/80 font-semibold transition-colors"
      >
        Apply for early access &rarr;
      </a>
    </div>
  </main>
</Layout>
