# Marketing site environment variables. Copy to .env.local for local dev.
# Never commit real values. Pull production values with `vercel env pull`.

# --- Neon (early-access lead storage) ---
# Pooled connection string for the DEDICATED marketing Neon database.
# Set on the Vercel project (Production + Preview) and locally for the
# migration scripts. This replaced the former Upstash/Vercel KV store.
DATABASE_URL=

# --- Cloudflare Turnstile (bot protection on the early-access form) ---
PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# Optional comma-separated hostname allowlist for solved Turnstile tokens.
# TURNSTILE_ALLOWED_HOSTNAMES=

# --- Resend (early-access notification email) ---
RESEND_API_KEY=

# --- One-time migration only (scripts/migrate-upstash-to-neon.mjs) ---
# Production Upstash creds, needed ONLY to copy existing leads out of KV.
# Remove after the migration is verified and KV is decommissioned.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
